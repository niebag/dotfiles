#!/usr/bin/env bash

# Pick a repository and focus its Herdr workspace. Workspaces are Herdr's
# project-level containers; a named session is a separate Herdr server.
#
# Usage:
#   herdr-workspacer           # use the current (or default) session
#   herdr-workspacer notive    # use the named "notive" session when outside Herdr

if [[ $# -gt 1 ]]; then
    echo "usage: herdr-workspacer [session-name]" >&2
    exit 2
fi

session_name=${1:-}

if [[ -n ${HERDR_PANE_ID:-} && -n $session_name ]]; then
    echo "Named Herdr sessions cannot be switched from inside a Herdr pane." >&2
    echo "Detach with Ctrl-b q, then run: herdr-workspacer $session_name" >&2
    exit 2
fi

selected=$({
    find ~/personal -mindepth 1 -maxdepth 1 -type d
    find ~/notive ~/resolph -mindepth 2 -maxdepth 2 -type d
} | fzf)

if [[ -z $selected ]]; then
    exit 0
fi

# Use an absolute, resolved path, matching the cwd stored by Herdr.
selected="$(cd -- "$selected" && pwd -P)" || exit 1
workspace_label="$(basename "$(dirname "$selected")")/$(basename "$selected")"

# Reuse the workspace for this repository when it already exists. Otherwise
# create and focus one through the surrounding Herdr server's API.
if [[ -n ${HERDR_PANE_ID:-} ]]; then
    workspace_id="$(
        herdr workspace list |
            jq -r --arg cwd "$selected" --arg label "$workspace_label" '
                (.result.workspaces // .workspaces // [])[]? |
                select(
                    .label == $label or
                    .workspace.label == $label or
                    (.root_pane.cwd? // .cwd? // "") == $cwd
                ) |
                (.workspace_id // .workspace.workspace_id // empty)
            ' |
            head -n 1
    )"

    if [[ -n $workspace_id ]]; then
        herdr workspace focus "$workspace_id" >/dev/null
    else
        herdr workspace create --cwd "$selected" --label "$workspace_label" --focus >/dev/null
    fi
else
    if [[ -n $session_name ]]; then
        cd -- "$selected"
        exec herdr --session "$session_name"
    fi

    cd -- "$selected"
    exec herdr
fi
