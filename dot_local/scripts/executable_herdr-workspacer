#!/usr/bin/env bash

# Pick a repository and create or focus its Herdr workspace.
# New workspaces include agent, git, app, and zsh tabs.
#
# Usage:
#   herdr-workspacer

selected=$( {
    find ~/personal -mindepth 1 -maxdepth 1 -type d
    find ~/notive ~/resolph -mindepth 2 -maxdepth 2 -type d
} | fzf ) || exit 0

[[ -n $selected ]] || exit 0
selected="$(cd -- "$selected" && pwd -P)" || exit 1
workspace_label="$(basename "$(dirname "$selected")")/$(basename "$selected")"

if [[ -z ${HERDR_PANE_ID:-} ]] && ! herdr status server 2>/dev/null | rg -qx 'status: running'; then
    nohup herdr server >/dev/null 2>&1 &
    for _ in {1..50}; do
        herdr status server 2>/dev/null | rg -qx 'status: running' && break
        sleep 0.1
    done
    herdr status server 2>/dev/null | rg -qx 'status: running' || exit 1
fi

workspace_id=$(herdr workspace list | jq -r --arg label "$workspace_label" '
    first(
        (.result.workspaces // .workspaces // [])[]? |
        select(.label == $label or .workspace.label == $label) |
        (.workspace_id // .workspace.workspace_id)
    ) // empty
')

tab_id() {
    herdr tab list --workspace "$workspace_id" | jq -r --arg label "$1" '
        first(
            (.result.tabs // .tabs // [])[]? |
            select(.label == $label) |
            .tab_id
        ) // empty
    '
}

run_in_tab() {
    local pane_id

    pane_id=$(herdr pane list --workspace "$workspace_id" | jq -r --arg tab_id "$1" '
        first(
            (.result.panes // .panes // [])[]? |
            select(.tab_id == $tab_id) |
            .pane_id
        ) // empty
    ')
    [[ -n $pane_id ]] || return 1
    herdr pane run "$pane_id" "$2" >/dev/null
}

if [[ -z $workspace_id ]]; then
    herdr workspace create --cwd "$selected" --label "$workspace_label" --focus >/dev/null
    workspace_id=$(herdr workspace list | jq -r --arg label "$workspace_label" '
        first(
            (.result.workspaces // .workspaces // [])[]? |
            select(.label == $label or .workspace.label == $label) |
            (.workspace_id // .workspace.workspace_id)
        ) // empty
    ')
    [[ -n $workspace_id ]] || exit 1

    agent_tab=$(herdr tab list --workspace "$workspace_id" | jq -r '
        first((.result.tabs // .tabs // [])[]? | .tab_id) // empty
    ')
    [[ -n $agent_tab ]] || exit 1

    case "$selected" in
        "$HOME/notive"/*) agent='claude --permission-mode auto' ;;
        *) agent='codex -a on-request -s workspace-write' ;;
    esac

    herdr tab rename "$agent_tab" agent >/dev/null
    run_in_tab "$agent_tab" "$agent" || exit 1

    herdr tab create --workspace "$workspace_id" --cwd "$selected" --label git --no-focus >/dev/null
    run_in_tab "$(tab_id git)" 'git status' || exit 1

    herdr tab create --workspace "$workspace_id" --cwd "$selected" --label app --no-focus >/dev/null
    herdr tab create --workspace "$workspace_id" --cwd "$selected" --label zsh --no-focus >/dev/null
    herdr tab focus "$agent_tab" >/dev/null
else
    herdr workspace focus "$workspace_id" >/dev/null
fi

[[ -n ${HERDR_PANE_ID:-} ]] || exec herdr
