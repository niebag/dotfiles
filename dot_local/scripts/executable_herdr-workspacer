#!/usr/bin/env bash

# Pick a repository and open its Herdr workspace.
# New workspaces get agent, git, app, and zsh tabs.
#
# Usage:
#   herdr-workspacer           # use the current or default session
#   herdr-workspacer work      # use the named session when outside Herdr

set -euo pipefail

if [[ $# -gt 1 ]]; then
    echo "usage: herdr-workspacer [session-name]" >&2
    exit 2
fi

session_name=${1:-}

if [[ -n ${HERDR_PANE_ID:-} && -n $session_name ]]; then
    echo "Named Herdr sessions cannot be switched from inside a Herdr pane." >&2
    exit 2
fi

die() {
    echo "$*" >&2
    exit 1
}

herdr_cmd() {
    if [[ -n $session_name ]]; then
        herdr --session "$session_name" "$@"
    else
        herdr "$@"
    fi
}

server_running() {
    herdr_cmd status server 2>/dev/null | rg -qx 'status: running'
}

ensure_server() {
    local attempt

    server_running && return

    if [[ -n $session_name ]]; then
        nohup herdr --session "$session_name" server >/dev/null 2>&1 &
    else
        nohup herdr server >/dev/null 2>&1 &
    fi

    for attempt in {1..50}; do
        server_running && return
        sleep 0.1
    done

    die "Could not start the Herdr session: ${session_name:-default}"
}

select_workspace() {
    {
        find ~/personal -mindepth 1 -maxdepth 1 -type d
        find ~/notive ~/resolph -mindepth 2 -maxdepth 2 -type d
    } | fzf
}

workspace_id() {
    herdr_cmd workspace list |
        jq -r --arg label "$workspace_label" '
            first(
                (.result.workspaces // .workspaces // [])[]? |
                select(.label == $label or .workspace.label == $label) |
                (.workspace_id // .workspace.workspace_id // empty)
            ) // empty
        '
}

tab_id() {
    local label=$1

    herdr_cmd tab list --workspace "$workspace_id" |
        jq -r --arg label "$label" '
            first(
                (.result.tabs // .tabs // [])[]? |
                select(.label == $label) |
                .tab_id
            ) // empty
        '
}

run_in_tab() {
    local tab_id=$1 command=$2 pane_id

    pane_id="$(
        herdr_cmd pane list --workspace "$workspace_id" |
            jq -r --arg tab_id "$tab_id" '
                first(
                    (.result.panes // .panes // [])[]? |
                    select(.tab_id == $tab_id) |
                    .pane_id
                ) // empty
            '
    )"
    [[ -n $pane_id ]] || die "Could not find a pane for tab: $tab_id"

    herdr_cmd pane run "$pane_id" "$command" >/dev/null
}

create_workspace() {
    local agent_tab_id git_tab_id agent

    herdr_cmd workspace create --cwd "$selected" --label "$workspace_label" --focus >/dev/null
    workspace_id=$(workspace_id)
    [[ -n $workspace_id ]] || die "Could not find the newly created $workspace_label workspace."

    agent_tab_id="$(
        herdr_cmd tab list --workspace "$workspace_id" |
            jq -r 'first((.result.tabs // .tabs // [])[]? | .tab_id) // empty'
    )"
    [[ -n $agent_tab_id ]] || die "Could not find the initial workspace tab."

    case "$selected" in
        "$HOME/notive"/*) agent='claude --permission-mode auto' ;;
        *) agent='codex -a on-request -s workspace-write' ;;
    esac

    herdr_cmd tab rename "$agent_tab_id" agent >/dev/null
    run_in_tab "$agent_tab_id" "$agent"

    herdr_cmd tab create --workspace "$workspace_id" --cwd "$selected" --label git --no-focus >/dev/null
    git_tab_id=$(tab_id git)
    [[ -n $git_tab_id ]] || die "Could not find the git tab."
    run_in_tab "$git_tab_id" 'git status'

    herdr_cmd tab create --workspace "$workspace_id" --cwd "$selected" --label app --no-focus >/dev/null
    herdr_cmd tab create --workspace "$workspace_id" --cwd "$selected" --label zsh --no-focus >/dev/null
    herdr_cmd tab focus "$agent_tab_id" >/dev/null
}

selected=$(select_workspace) || exit 0
[[ -n $selected ]] || exit 0
selected="$(cd -- "$selected" && pwd -P)"
workspace_label="$(basename "$(dirname "$selected")")/$(basename "$selected")"
workspace_id=""

if [[ -z ${HERDR_PANE_ID:-} ]]; then
    ensure_server
fi

workspace_id=$(workspace_id)
if [[ -n $workspace_id ]]; then
    herdr_cmd workspace focus "$workspace_id" >/dev/null
else
    create_workspace
fi

if [[ -z ${HERDR_PANE_ID:-} ]]; then
    if [[ -n $session_name ]]; then
        exec herdr session attach "$session_name"
    fi
    exec herdr
fi
