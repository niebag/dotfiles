#!/usr/bin/env bash

# Pick a repository and focus its Herdr workspace. Workspaces are Herdr's
# project-level containers; a named session is a separate Herdr server.
#
# Usage:
#   herdr-workspacer           # use the current (or default) session
#   herdr-workspacer work      # use the named "work" session when outside Herdr

if [[ $# -gt 1 ]]; then
    echo "usage: herdr-workspacer [session-name]" >&2
    exit 2
fi

session_name=${1:-}

if [[ -n ${HERDR_PANE_ID:-} && -n $session_name ]]; then
    echo "Named Herdr sessions cannot be switched from inside a Herdr pane." >&2
    echo "Detach with Ctrl-b q, then run: herdr-workspacer $session_name" >&2
    exit 2
fi

select_workspace() {
    {
        find ~/personal -mindepth 1 -maxdepth 1 -type d
        find ~/notive ~/resolph -mindepth 2 -maxdepth 2 -type d
    } | fzf
}

create_workspace() {
    herdr workspace create --cwd "$selected" --label "$workspace_label" --focus >/dev/null

    workspace_id=$(find_workspace)
    if [[ -z $workspace_id ]]; then
        echo "Could not find the newly created $workspace_label workspace." >&2
        exit 1
    fi

    create_workspace_tabs
}

find_workspace() {
    herdr workspace list |
        jq -r --arg cwd "$selected" --arg label "$workspace_label" '
            (.result.workspaces // .workspaces // [])[]? |
            select(
                .label == $label or
                .workspace.label == $label or
                (.root_pane.cwd? // .cwd? // "") == $cwd
            ) |
            (.workspace_id // .workspace.workspace_id // empty)
        ' |
        head -n 1
}

find_tab() {
    local tab_label=$1

    herdr tab list --workspace "$workspace_id" |
        jq -r --arg label "$tab_label" '
            (.result.tabs // .tabs // [])[]? |
            select(.label == $label) |
            .tab_id // empty
        ' |
        head -n 1
}

run_command() {
    local tab_id=$1 command=$2 pane_id

    pane_id="$(
        herdr pane list --workspace "$workspace_id" |
            jq -r --arg tab_id "$tab_id" '
                (.result.panes // .panes // [])[]? |
                select(.tab_id == $tab_id) |
                .pane_id // empty
            ' |
            head -n 1
    )"

    if [[ -n $pane_id ]]; then
        herdr pane run "$pane_id" "$command" >/dev/null
    fi
}

agent_command() {
    case "$selected" in
        "$HOME/notive"/*)
            printf '%s\n' 'claude --permission-mode auto'
            ;;
        *)
            printf '%s\n' 'codex -a on-request -s workspace-write'
            ;;
    esac
}

create_workspace_tabs() {
    local agent_tab_id git_tab_id app_tab_id

    agent_tab_id="$(
        herdr tab list --workspace "$workspace_id" |
            jq -r '(.result.tabs // .tabs // [])[]? | .tab_id // empty' |
            head -n 1
    )"
    if [[ -n $agent_tab_id ]]; then
        herdr tab rename "$agent_tab_id" agent >/dev/null
        run_command "$agent_tab_id" "$(agent_command)"
    fi

    herdr tab create --workspace "$workspace_id" --cwd "$selected" --label git --no-focus >/dev/null
    git_tab_id=$(find_tab git)
    run_command "$git_tab_id" 'git status'

    herdr tab create --workspace "$workspace_id" --cwd "$selected" --label app --no-focus >/dev/null
    app_tab_id=$(find_tab app)

    herdr tab create --workspace "$workspace_id" --cwd "$selected" --label zsh --no-focus >/dev/null

    if [[ -n $app_tab_id ]]; then
        herdr tab focus "$app_tab_id" >/dev/null
    fi
}

focus_workspace() {
    workspace_id="$(find_workspace)"

    if [[ -n $workspace_id ]]; then
        herdr workspace focus "$workspace_id" >/dev/null
    else
        create_workspace
    fi
}

workspace_id=""

selected=$(select_workspace)

if [[ -z $selected ]]; then
    exit 0
fi

# Use an absolute, resolved path, matching the cwd stored by Herdr.
selected="$(cd -- "$selected" && pwd -P)" || exit 1
workspace_label="$(basename "$(dirname "$selected")")/$(basename "$selected")"

if [[ -n ${HERDR_PANE_ID:-} ]]; then
    focus_workspace
else
    if [[ -n $session_name ]]; then
        cd -- "$selected"
        exec herdr --session "$session_name"
    fi

    cd -- "$selected"
    exec herdr
fi
