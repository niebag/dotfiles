#!/bin/sh

# chezmoi modify_ script for ~/.claude/settings.json.
#
# The current target file is piped in on stdin (empty on a fresh machine).
# This script only sets the "stable" keys below; everything else in the file
# (model, effortLevel, enabledPlugins, hooks, ...) passes straight through
# untouched. The SessionStart hook is intentionally NOT set here: herdr owns
# it (see run_onchange_install-herdr-integrations.sh).
#
# Output matches herdr's serialization (sorted keys via -S, no trailing
# newline) so the two tools don't ping-pong over formatting when herdr
# rewrites the file.
#
# jq flags:
#   -S            sort object keys (match herdr's output)
#   -n            start from null, don't auto-read stdin
#   --arg home    expose $home (the shell's home directory at run time)
#   (input? // {}) read the existing file if present, else start from {}

# If jq is somehow unavailable, pass the file through untouched rather than
# emitting an empty document. A modify_ script must never destroy its file.
if ! command -v jq >/dev/null 2>&1; then
  cat
  exit 0
fi

# printf '%s' strips jq's trailing newline (command substitution drops it, and
# printf adds none) to match herdr's newline-free output.
printf '%s' "$(jq -S -n --arg home "$HOME" '
  (input? // {})

  | .attribution = {commit: "", pr: ""}
  | .permissions.defaultMode = "auto"
  | .tui = "fullscreen"
  | .theme = "auto"

  | .statusLine = {
      type: "command",
      command: ("sh " + $home + "/.claude/statusline-command.sh")
    }
')"
